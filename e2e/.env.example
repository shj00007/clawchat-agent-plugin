# e2e 测试用例配置 —— 复制为 `e2e/.env` 并填入真实值。
# `.env` 已被 .gitignore，切勿提交（含 JWT）。

# ── 必填 ───────────────────────────────────────────────────────────────
# 移动端用户 JWT（Bearer），用于向 member-backend 申请 agent 连接码。
# 取自一个已登录的测试用户（test env / company.newbaselab.com）。
CLAWCHAT_JWT=

# clawling LLM 网关 key（sk-crawling-…）。agent 要靠它推理才能跑通 install-dev.md 的多步
# 安装指令；脚本会用它建一个 Secret，注入容器的 OPENAI_API_KEY / OPENROUTER_API_KEY。
LLM_API_KEY=

# ── 目标后端（test env / joe 集群；与 install-dev.md@dev 一致）────────────
# 仅用于本机申请连接码的那条 curl。插件安装/激活的目标后端由 install-dev.md@dev 自己
# 写死（同为 company.newbaselab.com:39001-3），脚本不重复传，故这里无需 *BASEURL 变量。
API_BASE=https://company.newbaselab.com:39001
# 申请连接码时带的 device id（沿用 apifox 模板里的值即可）。
DEVICE_ID=apifox

# ── 集群 / 镜像 ──────────────────────────────────────────────────────────
KUBECONFIG_PATH=~/.kube/dev.config
NAMESPACE=joe-clawchat-dev
# hermes-agent 镜像 tag（最新见 registry：
#   curl -s http://192.168.2.129:5000/v2/clawchat/hermes-agent/tags/list ）
HERMES_IMAGE_TAG=v2026.5.27

# ── 超时 ────────────────────────────────────────────────────────────────
# 安装→激活→连接 的总硬超时（秒）。超过即中断测试并返回结果。需求规定 3 分钟。
TIMEOUT_SECONDS=180
